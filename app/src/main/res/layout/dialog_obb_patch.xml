<?xml version="1.0" encoding="utf-8"?><!--
    OBB / DLC file selection dialog.
    Shows: title, message, select button.
    When processing starts: button GONE (hidden completely), replaced by progress spinner + two labels.
    No percent bar here — use ProgressDialog for downloads.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/devsa_rounded_shape_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvObbTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/primary_blue_devsa"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_blue"
            android:layout_marginBottom="16dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/tvObbMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Select button — GONE while processing -->
        <Button
            android:id="@+id/btnObbSelect"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/devsa_rounded_shape"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingHorizontal="36dp" />

        <!-- Processing state — GONE until user picks file -->
        <LinearLayout
            android:id="@+id/layoutProcessing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/patchSpinner"
                style="@android:style/Widget.ProgressBar.Large"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminate="true"
                android:indeterminateDrawable="@drawable/spinner_color_devsa"
                android:layout_marginBottom="16dp" />

            <!-- Main label — e.g. "ফাইল কপি হচ্ছে…" -->
            <TextView
                android:id="@+id/tvPatchStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_blue_devsa"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Sub label — e.g. "অনুগ্রহ করে অপেক্ষা করুন" -->
            <TextView
                android:id="@+id/tvPatchSubStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
