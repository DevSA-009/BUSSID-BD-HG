<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/devsa_rounded_shape_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/activation_title"
            android:textColor="@color/primary_blue_devsa"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_blue"
            android:layout_marginBottom="24dp"/>

        <!-- Key input -->
        <EditText
            android:id="@+id/etActivationKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_blue_devsa"
            android:hint="@string/activation_hint"
            android:textColor="@color/text_white"
            android:textColorHint="#88FFFFFF"
            android:textSize="15sp"
            android:inputType="textVisiblePassword"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:paddingBottom="10dp"
            android:layout_marginBottom="28dp"/>

        <!-- Activate button -->
        <Button
            android:id="@+id/btnActivate"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/devsa_rounded_shape"
            android:text="@string/activation_btn"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingHorizontal="40dp"
            android:layout_marginBottom="20dp"/>

        <!-- Reset link -->
        <TextView
            android:id="@+id/tvResetLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/activation_reset_link"
            android:textColor="@color/primary_blue_devsa"
            android:textSize="13sp"
            android:paddingVertical="8dp"/>

    </LinearLayout>
</ScrollView>
