<?xml version="1.0" encoding="utf-8"?>
<!--
    Reset Dialog — separate layout from activation.
    Title says "রিসেট কী দিন" not "অ্যাকাউন্ট রিসেট করুন" to avoid repeated header confusion.
    Only ONE input: resetKey. No email field.
    Back button label: "বাতিল" (Cancel in Bangla).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/devsa_rounded_shape_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/reset_dialog_title"
            android:textColor="@color/primary_blue_devsa"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_blue"
            android:layout_marginBottom="24dp"/>

        <!-- Info text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_dialog_info"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Reset Key input -->
        <EditText
            android:id="@+id/etResetKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary_blue_devsa"
            android:hint="@string/reset_hint"
            android:textColor="@color/text_white"
            android:textColorHint="#88FFFFFF"
            android:textSize="15sp"
            android:inputType="textVisiblePassword"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:paddingBottom="10dp"
            android:layout_marginBottom="28dp"/>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Cancel / Back button — label fixed to "বাতিল" -->
            <Button
                android:id="@+id/btnResetCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/devsa_rounded_shape_dialog"
                android:text="@string/btn_cancel"
                android:textColor="@color/primary_blue_devsa"
                android:textSize="14sp"
                android:layout_marginEnd="10dp"/>

            <!-- Submit reset button -->
            <Button
                android:id="@+id/btnResetSubmit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/devsa_rounded_shape"
                android:text="@string/reset_btn"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
